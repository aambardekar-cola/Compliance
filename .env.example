# ===========================================
# PaceCareOnline Compliance Intelligence Platform
# ===========================================

# Descope Authentication
DESCOPE_PROJECT_ID=your_descope_project_id
DESCOPE_MANAGEMENT_KEY=your_descope_management_key

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your_aws_account_id

# Database (Aurora Serverless v2 - auto-configured in production via CDK)
DATABASE_URL=postgresql+asyncpg://compliance_user:your_password@localhost:5432/compliance_db

# Amazon Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# GitLab (configured by admin in Settings UI)
# GITLAB_URL=https://gitlab.com
# GITLAB_TOKEN=your_gitlab_token
# GITLAB_PROJECT_IDS=123,456,789

# Jira Cloud (configured by admin in Settings UI)
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=your_email@company.com
# JIRA_API_TOKEN=your_jira_api_token
# JIRA_PROJECT_KEY=PCO

# Amazon SES
SES_FROM_EMAIL=compliance@collabrios.com
SES_REPLY_TO_EMAIL=support@collabrios.com

# Application
APP_ENV=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173
